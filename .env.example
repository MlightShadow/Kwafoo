# Kwafoo 环境变量配置模板
# 复制此文件为 .env 并修改对应值

# ===== 数据库 =====
DATABASE_PATH=data/kwafoo.db

# ===== AI 配置 =====
AI_BASE_URL=http://localhost:1234
AI_MODEL=nvidia/nemotron-3-nano-4b
AI_API_KEY=
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.7
AI_MAX_WORKERS=1
AI_BATCH_SIZE=1
AI_ENABLE_SUMMARY=true
AI_ENABLE_SUMMARY_COMMENT=true
AI_ENABLE_CLASSIFIER_REASONING=false
AI_ENABLE_SUMMARIZER_REASONING=false

# ===== AI 评论立场配置（隐私配置） =====
AI_COMMENT_STANCE_NATIONALITY=中国
AI_COMMENT_STANCE_GENDER=男
AI_COMMENT_STANCE_AGE=30
AI_COMMENT_STANCE_FAMILY_STATUS=已婚
AI_COMMENT_STANCE_INCOME=中等
AI_COMMENT_STANCE_HEALTH_STATUS=良好
AI_COMMENT_STANCE_RELIGION=无
AI_COMMENT_STANCE_CUSTOM_DESCRIPTION=

# ===== 服务器 =====
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_ENABLE_WEBSOCKET=true

# ===== 调度器 =====
SCHEDULER_FETCH_INTERVAL=1800
SCHEDULER_AI_PROCESS_INTERVAL=600
SCHEDULER_AUTO_FETCH=false
SCHEDULER_AUTO_AI_PROCESS=false

# ===== 日志 =====
LOGGING_LEVEL=INFO
LOGGING_FILE=data/logs/kwafoo.log

# ===== RAG =====
RAG_TOP_K=5
RAG_USE_FTS=true

# ===== 网络 =====
NETWORK_ENABLE_PROXY=false
NETWORK_PROXY_URL=

# ===== 图片 =====
IMAGE_ENABLE_FETCH=true