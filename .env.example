# Kwafoo 环境变量配置模板
# 复制此文件为 .env 并修改对应值
# 此文件用于覆盖 config.toml 中的配置，优先级更高

# ===== 数据库 =====
DATABASE_PATH=data/kwafoo.db

# ===== AI 配置 =====
AI_BASE_URL=http://localhost:1234
AI_MODEL=nvidia/nemotron-3-nano-4b
AI_API_KEY=
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.7
AI_MAX_WORKERS=1
AI_BATCH_SIZE=1
AI_ENABLE_SUMMARY=true
AI_SUMMARY_THRESHOLD=140
AI_MAX_INPUT_LENGTH=2000
AI_TIMEOUT=120
AI_ENABLE_SUMMARY_COMMENT=true
AI_ENABLE_CLASSIFIER_REASONING=false
AI_ENABLE_SUMMARIZER_REASONING=false

# ===== AI 评论立场配置（隐私配置） =====
AI_COMMENT_STANCE_NATIONALITY=中国
AI_COMMENT_STANCE_GENDER=男
AI_COMMENT_STANCE_AGE=30
AI_COMMENT_STANCE_FAMILY_STATUS=已婚
AI_COMMENT_STANCE_INCOME=中等
AI_COMMENT_STANCE_HEALTH_STATUS=良好
AI_COMMENT_STANCE_RELIGION=无
AI_COMMENT_STANCE_CUSTOM_DESCRIPTION=

# ===== 服务器 =====
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_ENABLE_WEBSOCKET=true

# ===== 调度器 =====
SCHEDULER_FETCH_INTERVAL=1800
SCHEDULER_AI_PROCESS_INTERVAL=600
SCHEDULER_AUTO_FETCH=false
SCHEDULER_AUTO_AI_PROCESS=false
SCHEDULER_AUTO_AI_AFTER_FETCH=false
SCHEDULER_MAX_FETCH_WORKERS=20

# ===== 日志 =====
LOGGING_LEVEL=INFO
LOGGING_FILE=data/logs/kwafoo.log
LOGGING_MAX_SIZE=10485760
LOGGING_BACKUP_COUNT=5

# ===== RAG =====
RAG_TOP_K=5
RAG_USE_FTS=true

# ===== 网络 =====
NETWORK_ENABLE_PROXY=false
NETWORK_PROXY_URL=

# ===== 图片 =====
IMAGE_ENABLE_FETCH=true
IMAGE_STORAGE_MODE=filesystem
IMAGE_STORAGE_PATH=data/images
IMAGE_THUMBNAIL_WIDTH=128
IMAGE_THUMBNAIL_HEIGHT=128
IMAGE_DISPLAY_POSITION=right
IMAGE_DISPLAY_SHOW_THUMBNAIL=true

# ===== 压缩 =====
COMPRESSION_ENABLE_COMPRESSION=true
COMPRESSION_TARGET_TOKENS=2000
COMPRESSION_COMPRESSION_LEVEL=balanced
COMPRESSION_ALGORITHM=auto
COMPRESSION_MODE=summary
COMPRESSION_MAX_IMAGE_SIZE=5242880

# ===== 正文抓取 =====
CONTENT_FETCH_ENABLE=true
CONTENT_FETCH_ALGORITHM=hybrid
CONTENT_FETCH_MIN_CONTENT_LENGTH=200
CONTENT_FETCH_MAX_CONTENT_LENGTH=10000
CONTENT_FETCH_TIMEOUT=30
CONTENT_FETCH_USE_PROXY=true
CONTENT_FETCH_ENABLE_CACHE=true

# ===== 报告 =====
REPORT_ENABLE_AUTO_GENERATE=false
REPORT_AUTO_GENERATE_TYPES=["daily"]
REPORT_DAILY_GENERATE_TIME=08:00
REPORT_WEEKLY_GENERATE_DAY=monday
REPORT_WEEKLY_GENERATE_TIME=09:00
REPORT_MONTHLY_GENERATE_DAY=1
REPORT_MONTHLY_GENERATE_TIME=10:00
REPORT_MAX_NEWS_COUNT=20
REPORT_AI_MODEL=nvidia/nemotron-3-nano-4b
REPORT_AI_TEMPERATURE=0.7
REPORT_AI_TIMEOUT=300